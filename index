<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Gamer Hub</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>🎮 Gamer Hub</h1>
        <p>Oyuncuların buluşma noktası</p>
    </header>

    <nav>
        <button onclick="showPage('anasayfa')">Ana Sayfa</button>
        <button onclick="showPage('oyunlar')">Oyunlar</button>
        <button onclick="showPage('hesap')">Hesap</button>
    </nav>

    <main id="icerik">
        <h2>Hoş geldin!</h2>
        <p>Bu site gamerlar için yapıldı 😎</p>
    </main>

    <script src="script.js"></script>
</body>
</html>
body {
    background-color: #0f172a;
    color: white;
    font-family: Arial;
    text-align: center;
}

header {
    background: #1e293b;
    padding: 20px;
}

button {
    margin: 10px;
    padding: 10px;
    background: #22c55e;
    border: none;
    cursor: pointer;
}
function showPage(sayfa) {
    let icerik = document.getElementById("icerik");

    if (sayfa === "anasayfa") {
        icerik.innerHTML = "<h2>Ana Sayfa</h2><p>Hoş geldin gamer 😎</p>";
    }

    if (sayfa === "oyunlar") {
        icerik.innerHTML = "<h2>Oyunlar</h2><p>Minecraft, CS2, GTA V</p>";
    }

    if (sayfa === "hesap") {
        icerik.innerHTML = `
            <h2>Giriş</h2>
            <input placeholder="Kullanıcı"><br><br>
            <input type="password" placeholder="Şifre"><br><br>
            <button onclick="alert('Giriş sistemi yakında 😎')">Giriş Yap</button>
        `;
    }
}
<div>
  <h3>Minecraft</h3>
  <p>En popüler sandbox oyunu</p>
</div>
<img src="https://via.placeholder.com/150">
button:hover {
    background: red;
}
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js"></script>

<script>
<h2>Kayıt / Giriş</h2>

<input id="email" placeholder="Email"><br><br>
<input id="password" type="password" placeholder="Şifre"><br><br>

<button onclick="register()">Kayıt Ol</button>
<button onclick="login()">Giriş Yap</button>

<script>
function register() {
  let email = document.getElementById("email").value;
  let pass = document.getElementById("password").value;

  auth.createUserWithEmailAndPassword(email, pass)
    .then(() => alert("Kayıt başarılı"))
    .catch(err => alert(err.message));
}

function login() {
  let email = document.getElementById("email").value;
  let pass = document.getElementById("password").value;

  auth.signInWithEmailAndPassword(email, pass)
    .then(() => alert("Giriş başarılı"))
    .catch(err => alert(err.message));
}
</script>
let puan = 0;

function puanEkle() {
  puan += 10;
  document.getElementById("puan").innerText = puan;
}
<h3>Puan: <span id="puan">0</span></h3>
<button onclick="puanEkle()">Puan kazan</button>
<input id="mesaj" placeholder="Mesaj yaz">
<button onclick="gonder()">Gönder</button>

<div id="chat"></div>

<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js"></script>

<script>
const db = firebase.database();

function gonder() {
  let mesaj = document.getElementById("mesaj").value;
  db.ref("chat").push(mesaj);
}

db.ref("chat").on("value", (snapshot) => {
  let data = snapshot.val();
  let html = "";

  for (let id in data) {
    html += "<p>" + data[id] + "</p>";
  }

  document.getElementById("chat").innerHTML = html;
});
</script>
